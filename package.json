{
  "name": "@smotra/frontend",
  "version": "0.0.1",
  "description": "Web frontend UI for Smotra distributed monitoring system - Single-page application with OAuth2, real-time updates, and responsive design",
  "keywords": [
    "smotra",
    "monitoring",
    "distributed-system",
    "frontend",
    "spa",
    "typescript",
    "oauth2",
    "websocket",
    "responsive-design",
    "bulma"
  ],
  "homepage": "https://github.com/smotra-monitoring/frontend#readme",
  "bugs": {
    "url": "https://github.com/smotra-monitoring/frontend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smotra-monitoring/frontend.git"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Ivan Kuchin",
    "email": "ikuchin@smotra.dev"
  },
  "contributors": [],
  "type": "module",
  "main": "public/index.html",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "browser-sync start --server 'public' --files 'public' --single",
    "dev": "browser-sync start --server 'public' --files 'public' --single --port 3000 --no-notify",
    "openapi-ts": "openapi-ts -f ./api/openapi-ts.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0",
    "@types/node": "^25",
    "typescript": "^6",
    "browser-sync": "^3",
    "vitest": "^4",
    "@vitest/coverage-v8": "^4",
    "jsdom": "^25"
  }
}