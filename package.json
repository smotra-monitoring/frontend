{
  "name": "frontend",
  "version": "0.0.1",
  "description": "Web frontend UI for smotra monitoring system",
  "keywords": [
    "smotra",
    "distributed monitoring system",
    "frontend"
  ],
  "license": "Apache-2.0",
  "author": "Ivan Kuchin",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "openapi-ts": "openapi-ts -f ./api/openapi-ts.config.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.92.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.2.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3"
  }
}